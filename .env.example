# Pathos AI — Environment Configuration Template
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Core ---------------------------------------------------------------
ENVIRONMENT=local
DEBUG=true
ALLOWED_CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# --- Security -------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=replace-with-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Database ---------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///./pathos_ai.db
# Production example:
# DATABASE_URL=postgresql+asyncpg://pathos:password@localhost:5432/pathos_ai

# --- LLM Provider (choose one) ------------------------------------------------
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-replace-me
ANTHROPIC_API_KEY=
GENERATION_MODEL=gpt-4o-mini
GENERATION_TEMPERATURE=0.2

# --- Vector store ------------------------------------------------------------
VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=pathos_clinical_kb
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# --- Observability -------------------------------------------------------------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pathos-ai
OTEL_EXPORTER_ENDPOINT=
